# ──────────────────────────────────────────────
# Chulbul AI — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Groq API Key (required) — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.6
GROQ_MAX_TOKENS=2048

# Speech-to-Text (faster-whisper) — runs locally, no key needed
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Text-to-Speech voices (edge-tts — free, no key needed)
TTS_VOICE_EN=en-US-GuyNeural
TTS_VOICE_HI=hi-IN-MadhurNeural

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Feature flags
ENABLE_BROWSER_TOOL=false
